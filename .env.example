# Public URL for the audience deck (waiting room “Jetzt mitmachen” link). Override per env if needed.
NEXT_PUBLIC_AUDIENCE_URL=https://whois.duby.io

# Canonical origin for Open Graph / Twitter cards (no trailing slash). Set on Vercel Production to whois.duby.io.
NEXT_PUBLIC_SITE_URL=https://whois.duby.io

# Optional: live slide sync (Supabase). Without these, the deck still works with ?s= deep links.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# --- Deck session (one UUID per environment) ---------------------------------
# All Realtime slide sync, presence, polls, and lobby state use this row.
# Use a DIFFERENT row (different UUID) for local, Vercel Preview/staging, and Production
# so you never cross streams. Easiest: three INSERTs, copy each id into the matching env.
#
#   insert into public.deck_sessions (environment_label) values ('local') returning id;
#   insert into public.deck_sessions (environment_label) values ('staging') returning id;
#   insert into public.deck_sessions (environment_label) values ('production') returning id;
#
# Stricter isolation: use separate Supabase projects for prod vs non-prod, each with its own row.
#
# presentation_started_at (nullable): lobby until presenter calls POST /api/present/start.
NEXT_PUBLIC_DECK_SESSION_ID=

# Server-only: used by POST /api/present to update deck_sessions.
# Same value gates /present via /present/login (HttpOnly cookie + JWT) and optional Bearer header.
SUPABASE_SERVICE_ROLE_KEY=
PRESENTER_SECRET=choose_a_long_random_string

# Optional: audience “Passwort-Modus” — browse slides before go-live (HttpOnly cookie + JWT).
# Must match NEXT_PUBLIC_DECK_SESSION_ID on the server; used as the JWT signing secret after check.
VISITOR_PASSWORD=

# Vercel: set env vars per scope so Preview ≠ Production:
#   Production  → Production env: NEXT_PUBLIC_DECK_SESSION_ID = production row UUID
#   Preview     → Preview env:    NEXT_PUBLIC_DECK_SESSION_ID = staging row UUID
# Local: .env.local with local row UUID (never commit).
# Enable Realtime for public.deck_sessions (see migration comments / Supabase Dashboard → Publications).
