# Optional: live slide sync (Supabase). Without these, the deck still works with ?s= deep links.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# UUID of a single row in public.deck_sessions (see supabase/migrations).
NEXT_PUBLIC_DECK_SESSION_ID=

# Server-only: used by POST /api/present to update deck_sessions.
SUPABASE_SERVICE_ROLE_KEY=
PRESENTER_SECRET=choose_a_long_random_string

# Vercel: Project Settings → Environment Variables → add the same keys for Preview/Production.
# After applying supabase/migrations, insert one row: insert into deck_sessions default values returning id;
# Enable Realtime for public.deck_sessions in Supabase (Database → Publications, or run the alter publication line from the migration comment).
